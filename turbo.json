{
    "$schema": "https://turborepo.org/schema.json",
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "outputs": [".next/**", "dist/**"],
        "env": ["STRIPE_SECRET_KEY", "STRIPE_WEBHOOK_SECRET"]
      },
      "dev": {
        "cache": false
      },
      "lint": {}
    }
  }